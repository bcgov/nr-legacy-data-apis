# Oracle Free local container
ORACLE_HOST_PORT=1522
ORACLE_PASSWORD=change-me
ORACLE_APP_USER=legacy_app
ORACLE_APP_PASSWORD=legacy_app_password

# ORDS -> Oracle local container
ORDS_DB_HOST=oracle-free
ORDS_DB_PORT=1521
ORDS_DB_SERVICE=FREEPDB1
ORDS_SYS_PASSWORD=change-me
ORDS_FORCE_SECURE=FALSE
ORDS_DEBUG=FALSE

# DB2REST -> Oracle local container
DB2REST_HOST_PORT=8081
DB2REST_URL=jdbc:oracle:thin:@//oracle-free:1521/FREEPDB1
DB2REST_USER=legacy_app
DB2REST_PASSWORD=legacy_app_password
DB2REST_ID=oracle
DB2REST_INCLUDED_SCHEMAS=LEGACY_APP
DB2REST_FETCH_LIMIT=100

# DAB -> SQL Server on-prem
SQLSERVER_CONNECTION_STRING=Server=host.docker.internal,1433;Database=master;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=true;